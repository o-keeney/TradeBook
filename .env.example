# --- Next.js (apps/web) — use apps/web/.env.local for next dev (NEXT_PUBLIC_* is inlined at build time)
NEXT_PUBLIC_API_URL=http://localhost:8787

# API CORS: set in apps/api/wrangler.toml [vars] CORS_ORIGINS or dashboard for production web origin(s)
#
# Portfolio images: R2 bucket `tradebook-media` is bound as MEDIA_BUCKET in apps/api/wrangler.toml
# (create with: wrangler r2 bucket create tradebook-media)

# --- API worker (apps/api) — use wrangler secret put <NAME> for production
# Brevo (transactional email)
# BREVO_API_KEY=

# Stripe (subscriptions)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Mapbox (maps)
# MAPBOX_ACCESS_TOKEN=

# BudgetSMS (SMS)
# BUDGETSMS_USER=
# BUDGETSMS_PASSWORD=

# Google AdSense (client id in frontend when you add the script)
# NEXT_PUBLIC_ADSENSE_CLIENT=
