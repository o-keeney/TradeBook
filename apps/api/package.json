{
  "name": "api",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "dev": "node run-wrangler.mjs dev",
    "deploy": "node run-wrangler.mjs deploy",
    "cf-typegen": "node run-wrangler.mjs types --env-interface Env src/env.d.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "node run-wrangler.mjs d1 migrations apply tradebook-db --local",
    "db:migrate:remote": "node run-wrangler.mjs d1 migrations apply tradebook-db --remote",
    "create-admin": "node scripts/create-admin-user.mjs",
    "create-admin:apply": "node scripts/create-admin-user.mjs && node run-wrangler.mjs d1 execute tradebook-db --local --file=scripts/last-admin-insert.sql",
    "test": "vitest run"
  },
  "dependencies": {
    "@tradebook/construction-professions": "file:../../packages/construction-professions",
    "bcryptjs": "^3.0.2",
    "drizzle-orm": "^0.41.0",
    "hono": "^4.7.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@cloudflare/workers-types": "^4.20250317.0",
    "drizzle-kit": "^0.31.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.5",
    "wrangler": "^4.65.0"
  }
}
